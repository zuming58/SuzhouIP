PORT=8787

# Leave MOCK_MODE=1 for local UI testing without Volcengine credentials.
# Set MOCK_MODE=0 only after VOLC_ACCESS_KEY is filled.
MOCK_MODE=1

# Optional. Old console auth may require APP ID; new console API Key auth can leave it empty.
VOLC_APP_ID=

# Console Access Token / API Key secret.
VOLC_ACCESS_KEY=your_access_token
VOLC_RESOURCE_ID=volc.speech.dialog
VOLC_APP_KEY=PlgvMymc7f3tQnJ6
VOLC_REALTIME_URL=wss://openspeech.bytedance.com/api/v3/realtime/dialogue

# O2.0: 1.2.1.1, SC2.0: 2.2.0.0
# The default vv voice belongs to O/O2.0, so keep O2.0 until a SC2.0 clone voice is ready.
VOLC_MODEL=1.2.1.1
VOLC_SPEAKER=zh_female_vv_jupiter_bigtts
VOLC_INPUT_MOD=text
