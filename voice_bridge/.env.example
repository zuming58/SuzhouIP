# 苏丽娘 voice_bridge 配置示例
# 复制为 .env 后填写真实密钥；不要提交 .env。

PORT=8788
MOCK_MODE=0

# 火山/豆包实时语音配置
VOLC_ACCESS_KEY=
VOLC_APP_ID=
VOLC_APP_KEY=
VOLC_MODEL=1.2.1.1
VOLC_RESOURCE_ID=
VOLC_SPEAKER=
VOLC_REALTIME_URL=
VOLC_INPUT_MOD=text

# 对话状态抽取 LLM（OpenAI 兼容接口 / 火山方舟 / 中转站均可）
# 开启后：多轮用户原话 → LLM 总结 routeDraft JSON → 确认卡/生成路线
STATE_LLM_API_KEY=
STATE_LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
STATE_LLM_MODEL=doubao-seed-1-6-250615

# 也可以使用 OPENAI_* 或 ARK_* 变量名：
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
# OPENAI_MODEL=
# ARK_API_KEY=
# ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# ARK_MODEL=doubao-seed-1-6-250615

# 如果确认 VOLC_ACCESS_KEY 也可用于方舟 Chat Completions，再显式开启：
# VOLC_STATE_LLM=1
# VOLC_STATE_MODEL=doubao-seed-1-6-250615
